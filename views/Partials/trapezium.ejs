<div style="/*border:1px solid green;*/" class="trapezium <%=reflect?"reflect":""%>">
  <svg style="/*border:1px solid red;*/" class="<%= className %>" height="100%" width="100%" viewBox="0 0 200 100">
    <polygon points="<%=reflect?"0,0 50,100 200,100 200,0":"0,0 0,100 150,100 200,0"%>" class="<%=color%>"/>
  </svg>
  <% if(content){ %>
    <p><%= content %></p>
  <% } %>
</div>